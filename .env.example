# ============================================
# Legal AI Agent — Environment Variables
# ============================================

# === App ===
APP_PORT=8080
SECRET_KEY=change-me-to-random-string
JWT_SECRET=change-me-to-random-jwt-secret

# === Ollama (Local LLM) ===
# Ollama must be running locally.
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=gemma3:4b

# === Database (Supabase / PostgreSQL) ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_KEY=your-service-role-key

# PostgreSQL connection for vector/pgvector operations
SUPABASE_DB_HOST=db.your-project.supabase.co
SUPABASE_DB_PORT=5432
SUPABASE_DB_PASSWORD=your-db-password
DB_NAME=postgres
DB_USER=postgres
DB_SSL_MODE=require

# === CrawlKit (for web crawling Indian law sites) ===
# Get your free API key at https://crawlkit.org
CRAWLKIT_API_KEY=ck_free_xxx
